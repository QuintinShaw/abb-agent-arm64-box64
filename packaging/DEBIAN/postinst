#!/bin/sh
set -e

BOX64_BIN=""
if [ -x /usr/local/bin/box64 ]; then
    BOX64_BIN=/usr/local/bin/box64
elif [ -x /usr/bin/box64 ]; then
    BOX64_BIN=/usr/bin/box64
fi

if [ -z "$BOX64_BIN" ]; then
    echo "ERROR: box64 was not found at /usr/local/bin/box64 or /usr/bin/box64." >&2
    echo "Install Box64 first. Options:" >&2
    echo "  - distro/community package if available" >&2
    echo "  - sudo /usr/share/doc/abb-agent-arm64-box64/install-box64.sh" >&2
    echo "  - manual install from https://github.com/ptitSeb/box64" >&2
    exit 1
fi

for cmd in dkms gcc make modprobe; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "ERROR: missing required command: $cmd" >&2
        exit 1
    fi
done

if [ ! -e "/lib/modules/$(uname -r)/build" ]; then
    echo "ERROR: kernel headers for $(uname -r) are missing." >&2
    echo "Install the matching linux-headers package, then rerun:" >&2
    echo "  sudo dpkg-reconfigure abb-agent-arm64-box64" >&2
    exit 1
fi

install -d -m 0755 /opt/synosnap

if [ -d /usr/src/synosnap-0.12.10 ]; then
    dkms add -m synosnap -v 0.12.10 2>/dev/null || true
    dkms build -m synosnap -v 0.12.10
    dkms install -m synosnap -v 0.12.10
    modprobe synosnap || true
else
    echo "WARNING: /usr/src/synosnap-0.12.10 not found; DKMS module was not installed." >&2
fi

systemctl daemon-reload || true

echo "abb-agent-arm64-box64 installed."
echo "Service was not enabled automatically."
echo "Start it with: sudo systemctl start abb-box64.service"
echo "If the official payload includes abb-cli, register with: sudo abb-cli -c"

exit 0
